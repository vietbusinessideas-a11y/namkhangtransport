{
  "rewrites": [
    { "source": "/login",    "destination": "/login.html" },
    { "source": "/driver",   "destination": "/driver.html" },
    { "source": "/",         "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
